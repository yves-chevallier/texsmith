% Fancy style (colored, icons)
\renewcommand{\texsmithCalloutTitleFormat}[1]{\raisebox{0.2em}{\bfseries ~#1}}
\tcbset{callout base/.style={
  breakable,
  enhanced,
  arc=0.7mm,
  boxrule=0.1mm,
  titlerule=0mm,
  left=3mm,
  lefttitle=0.8mm,
  leftupper=1.5mm,
  coltitle=black,
  fonttitle=\bfseries\sffamily,
  parbox=false,
}}
\tcbset{
  callout note/.style={
    callout base,
    colback=white,
    colframe=calloutNoteFrame,
    colbacktitle=calloutNoteFrame!5!white,
    coltitle=calloutNoteTitle,
    borderline west={1.5mm}{0mm}{calloutNoteFrame},
    title={\makebox[1.6em][c]{\raisebox{0.05em}{\scalebox{1.1}{\texsmithCalloutIcon{📝}}}}},
  }
}
