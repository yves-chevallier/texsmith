  boxrule=0.07em,
  fonttitle=\bfseries,
  top=1mm,
  left=1mm,
  arc=0.5mm,
  bottom=1mm,
  title={#3},
  list entry={\protect\numberline{\thetcbcounter}#3},
  #1
}

